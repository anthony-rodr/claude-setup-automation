# Release zips — created by Package-Release.ps1, uploaded to GitHub Releases
*.zip

# Bundled installers — downloaded locally by Package-Release scripts, not committed
bundled/
# Allow .gitkeep placeholders so the bundled/ directories exist in fresh clones
!.gitkeep

# Logs
*.log

# Node modules (chatbot dependencies)
node_modules/
package-lock.json

# Editor / OS
.vscode/settings.json
Thumbs.db
Desktop.ini

# Local reference docs
COMMANDS.md
CLAUDE.md
