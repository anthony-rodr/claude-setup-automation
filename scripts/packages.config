<?xml version="1.0" encoding="utf-8"?>
<!--
  Chocolatey bulk install list for Master Electronics dev environment.
  Used by Install-DevEnvironment.ps1 as a fast-path single choco call
  before the per-package fallback loop.

  Excludes: nvm-windows (choco nvm silently no-ops as SYSTEM),
            Python 3.12 (choco python312 exits 1638 with registry remnants; use direct/winget),
            WSL2 (installed via wsl.exe, not choco).
-->
<packages>
  <package id="git" />
  <package id="vscode" />
  <package id="powershell-core" />
  <package id="gh" />
  <package id="docker-desktop" />
  <package id="awscli" />
  <package id="terraform" />
</packages>
