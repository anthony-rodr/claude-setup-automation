<?xml version="1.0" encoding="utf-8"?>
<!--
  Chocolatey bulk install list for Master Electronics dev environment.
  Used by Install-DevEnvironment.ps1 as a fast-path single choco call
  before the per-package fallback loop.

  Excludes (have bundled installers — Tier 0 in per-package loop handles these locally):
    git, vscode, gh, awscli, terraform, python312

  Also excludes:
    nvm-windows  — choco nvm silently no-ops as SYSTEM; use direct download
    WSL2         — installed via wsl.exe, not choco

  Only packages with NO bundled version that must download at install time.
-->
<packages>
  <package id="powershell-core" />
  <package id="docker-desktop" />
  <package id="claude" />
</packages>
